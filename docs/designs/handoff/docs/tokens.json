{
  "$schema": "https://schemas.vallista.land/tokens.v1.json",
  "meta": {
    "name": "vallista-land",
    "version": "2.0.0",
    "mode": "light-first",
    "updated": "2024-11"
  },
  "core": {
    "gray": {
      "50":  "#fafbfc",
      "100": "#f1f2f6",
      "200": "#e6e8ee",
      "300": "#d2d6df",
      "400": "#9aa1b4",
      "500": "#6b7389",
      "600": "#3a4255",
      "700": "#252c3d",
      "800": "#131a2b",
      "900": "#0b1220"
    },
    "blue": {
      "50":  "#eff4ff",
      "500": "#2b6cff",
      "600": "#1f56d6"
    },
    "green": { "50": "#e8f6ee", "700": "#2a7f3f" },
    "amber": { "50": "#fff7ed", "700": "#8a6628" },
    "red":   { "50": "#fef2f2", "700": "#b91c1c" }
  },
  "semantic": {
    "light": {
      "bg":          "#ffffff",
      "bgSoft":      "{core.gray.50}",
      "bgOverlay":   "rgba(11, 18, 32, 0.35)",
      "ink":         "{core.gray.900}",
      "ink2":        "{core.gray.600}",
      "ink3":        "{core.gray.500}",
      "ink4":        "{core.gray.400}",
      "line":        "{core.gray.200}",
      "line2":       "{core.gray.100}",
      "accent":      "{core.blue.500}",
      "accentHover": "{core.blue.600}",
      "accentTint":  "{core.blue.50}",
      "focusRing":   "0 0 0 2px #ffffff, 0 0 0 4px rgba(43,108,255,0.55)"
    },
    "dark": {
      "bg":          "{core.gray.900}",
      "bgSoft":      "{core.gray.800}",
      "bgOverlay":   "rgba(0, 0, 0, 0.6)",
      "ink":         "#ffffff",
      "ink2":        "#dbe2ff",
      "ink3":        "{core.gray.400}",
      "ink4":        "{core.gray.500}",
      "line":        "#1c2540",
      "line2":       "#131c33",
      "accent":      "{core.blue.500}",
      "accentHover": "{core.blue.600}",
      "accentTint":  "rgba(43, 108, 255, 0.18)",
      "focusRing":   "0 0 0 2px #0b1220, 0 0 0 4px rgba(43,108,255,0.65)"
    }
  },
  "space": {
    "1":  "4px", "2":  "8px", "3":  "12px",  "4":  "16px",
    "5":  "20px","6":  "24px","8":  "32px", "10": "40px",
    "12": "48px","16": "64px","20": "80px"
  },
  "radius": {
    "1": "4px", "2": "6px", "3": "8px", "4": "10px",
    "5": "12px", "6": "14px", "pill": "999px"
  },
  "elevation": {
    "0": "none",
    "1": "0 1px 0 rgba(11, 18, 32, 0.04)",
    "2": "0 2px 6px rgba(11, 18, 32, 0.06)",
    "3": "0 12px 32px rgba(11, 18, 32, 0.10)",
    "4": "0 24px 60px rgba(11, 18, 32, 0.20), 0 2px 6px rgba(11, 18, 32, 0.06)"
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "180ms", "slow": "320ms" },
    "easing": {
      "out":    "cubic-bezier(0.2, 0.7, 0.3, 1)",
      "in":     "cubic-bezier(0.4, 0, 1, 1)",
      "inout":  "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "zIndex": {
    "nav": 10, "tocRail": 20, "scrim": 900,
    "modal": 1000, "tooltip": 1100, "toast": 1200
  },
  "typography": {
    "family": {
      "sans": "\"Pretendard Variable\", Pretendard, -apple-system, BlinkMacSystemFont, system-ui, \"Apple SD Gothic Neo\", sans-serif",
      "mono": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
    },
    "scale": {
      "display":       { "size": "48px", "line": "1.10", "weight": 700, "tracking": "-1px" },
      "h1":            { "size": "44px", "line": "1.15", "weight": 700, "tracking": "-0.8px" },
      "h1Archive":     { "size": "32px", "line": "1.20", "weight": 700, "tracking": "-0.5px" },
      "h2":            { "size": "26px", "line": "1.25", "weight": 700, "tracking": "-0.3px" },
      "h3":            { "size": "19px", "line": "1.30", "weight": 600, "tracking": "-0.2px" },
      "h4":            { "size": "17px", "line": "1.35", "weight": 600, "tracking": "-0.2px" },
      "lede":          { "size": "18px", "line": "1.55", "weight": 400, "tracking": "0" },
      "body":          { "size": "17px", "line": "1.85", "weight": 400, "tracking": "0" },
      "bodyUi":        { "size": "14px", "line": "1.60", "weight": 400, "tracking": "0" },
      "small":         { "size": "13px", "line": "1.60", "weight": 400, "tracking": "0" },
      "caption":       { "size": "12px", "line": "1.50", "weight": 500, "tracking": "0" },
      "overlineMono":  { "size": "11px", "line": "1.20", "weight": 500, "tracking": "0.14em", "family": "mono", "uppercase": true },
      "kbdMono":       { "size": "11px", "line": "1.20", "weight": 500, "tracking": "0.10em", "family": "mono" },
      "code":          { "size": "13px", "line": "1.75", "weight": 400, "tracking": "0", "family": "mono" }
    }
  },
  "layout": {
    "readingColumn": "720px",
    "sidebar": "220px",
    "cardGutter": { "desktop": "24px", "mobile": "16px" },
    "rowGap": "40px",
    "sectionGap": "64px"
  }
}
