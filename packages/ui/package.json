{
  "name": "@vallista/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Vallista UI — Astro + vanilla-extract components following designs/handoff",
  "sideEffects": [
    "**/*.css",
    "**/*.css.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/styles/theme.css.ts",
    "./global.css": "./src/styles/global.css.ts",
    "./tokens.json": "./src/styles/tokens.json",
    "./components/*": "./src/components/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0",
    "@vanilla-extract/css": "^1.14.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vanilla-extract/css": "^1.17.4",
    "typescript": "~5.7.2"
  }
}
