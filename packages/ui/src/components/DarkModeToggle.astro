---
import { toggle, iconLight, iconDark } from './DarkModeToggle.css'
---

<button
  type='button'
  class={toggle}
  aria-label='테마 변경'
  onclick='window.__vallistaThemeCycle && window.__vallistaThemeCycle()'
>
  <svg
    class={iconLight}
    width='16'
    height='16'
    viewBox='0 0 16 16'
    fill='none'
    stroke='currentColor'
    stroke-width='1.4'
    stroke-linecap='round'
  >
    <circle cx='8' cy='8' r='3'></circle>
    <path d='M8 1v2M8 13v2M1 8h2M13 8h2M3.5 3.5l1.4 1.4M11.1 11.1l1.4 1.4M3.5 12.5l1.4-1.4M11.1 4.9l1.4-1.4'></path>
  </svg>
  <svg
    class={iconDark}
    width='16'
    height='16'
    viewBox='0 0 16 16'
    fill='none'
    stroke='currentColor'
    stroke-width='1.4'
  >
    <path d='M13 9.5A5 5 0 1 1 6.5 3a4 4 0 0 0 6.5 6.5Z'></path>
  </svg>
</button>
