---
import { card } from './Card.css'

interface Props {
  href?: string
  class?: string
}

const { href, class: className } = Astro.props
const classes = [card, className].filter(Boolean).join(' ')
---

{
  href ? (
    <a class={classes} href={href}>
      <slot />
    </a>
  ) : (
    <div class={classes}>
      <slot />
    </div>
  )
}
