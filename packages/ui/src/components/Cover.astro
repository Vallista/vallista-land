---
import { cover, svg } from './Cover.css'

type Kind = 'grid' | 'stripes' | 'dots' | 'blocks' | 'lines'

interface Props {
  kind?: Kind
  ratio?: string
  class?: string
}

const { kind = 'grid', ratio = '16 / 9', class: className } = Astro.props
const classes = [cover, className].filter(Boolean).join(' ')
---

<div class={classes} style={`aspect-ratio: ${ratio}`} role='img' aria-hidden='true'>
  {
    kind === 'grid' && (
      <svg
        class={svg}
        viewBox='0 0 400 225'
        preserveAspectRatio='none'
        fill='currentColor'
      >
        <g opacity='0.18'>
          {Array.from({ length: 21 }, (_, i) => (
            <line x1={i * 20} y1='0' x2={i * 20} y2='225' stroke='currentColor' stroke-width='0.5' />
          ))}
          {Array.from({ length: 13 }, (_, i) => (
            <line x1='0' y1={i * 18} x2='400' y2={i * 18} stroke='currentColor' stroke-width='0.5' />
          ))}
        </g>
        <circle cx='300' cy='90' r='42' opacity='0.35' />
        <rect x='70' y='130' width='80' height='60' rx='6' opacity='0.55' />
      </svg>
    )
  }
  {
    kind === 'stripes' && (
      <svg
        class={svg}
        viewBox='0 0 400 225'
        preserveAspectRatio='none'
        fill='currentColor'
      >
        <defs>
          <pattern id='stripes-pat' width='18' height='18' patternUnits='userSpaceOnUse' patternTransform='rotate(45)'>
            <rect x='0' y='0' width='9' height='18' fill='currentColor' opacity='0.35' />
          </pattern>
        </defs>
        <rect width='400' height='225' fill='url(#stripes-pat)' />
      </svg>
    )
  }
  {
    kind === 'dots' && (
      <svg
        class={svg}
        viewBox='0 0 400 225'
        preserveAspectRatio='none'
        fill='currentColor'
      >
        <g opacity='0.45'>
          {Array.from({ length: 14 }, (_, x) =>
            Array.from({ length: 8 }, (_, y) => (
              <circle cx={20 + x * 28} cy={18 + y * 28} r='2.5' />
            ))
          )}
        </g>
      </svg>
    )
  }
  {
    kind === 'blocks' && (
      <svg
        class={svg}
        viewBox='0 0 400 225'
        preserveAspectRatio='none'
        fill='currentColor'
      >
        <rect x='30' y='40' width='140' height='110' rx='6' opacity='0.2' />
        <rect x='90' y='80' width='160' height='110' rx='6' opacity='0.4' />
        <rect x='190' y='50' width='170' height='130' rx='6' opacity='0.6' />
      </svg>
    )
  }
  {
    kind === 'lines' && (
      <svg
        class={svg}
        viewBox='0 0 400 225'
        preserveAspectRatio='none'
        stroke='currentColor'
        fill='none'
        stroke-width='1.2'
      >
        <path d='M20 190 L120 140' opacity='0.4' />
        <path d='M120 140 L220 110' opacity='0.55' />
        <path d='M220 110 L320 60' opacity='0.7' />
        <path d='M20 210 L380 210' opacity='0.2' />
      </svg>
    )
  }
</div>
