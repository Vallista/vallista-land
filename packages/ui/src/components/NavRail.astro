---
import {
  rail,
  brand,
  brandMark,
  brandMarkImg,
  brandMarkInitial,
  brandText,
  brandName as brandNameStyle,
  brandRole as brandRoleStyle,
  nav,
  navLink,
  navCount,
  railFooter,
  footerLink,
  seriesSection,
  seriesTitle,
  seriesLink,
  seriesCount
} from './NavRail.css'

interface Count {
  articles?: number
  notes?: number
  projects?: number
}

export interface SeriesItem {
  name: string
  slug: string
  count: number
}

interface Props {
  path: string
  counts?: Count
  brandName?: string
  brandRole?: string
  brandHref?: string
  brandAvatar?: string
  series?: SeriesItem[]
}

const {
  path,
  counts = {},
  brandName = 'Vallista',
  brandRole = 'software engineer',
  brandHref = '/',
  brandAvatar,
  series = []
} = Astro.props

const initial = brandName.charAt(0).toUpperCase()

function current(prefix: string): 'page' | undefined {
  if (prefix === '/') return path === '/' ? 'page' : undefined
  return path === prefix || path.startsWith(prefix + '/') ? 'page' : undefined
}

function seriesCurrent(slug: string): 'page' | undefined {
  const href = `/series/${slug}`
  return path === href ? 'page' : undefined
}
---

<aside class={rail}>
  <a href={brandHref} class={brand}>
    <span class={brandMark}>
      <span class={brandMarkInitial} aria-hidden='true'>{initial}</span>
      {
        brandAvatar && (
          <img
            src={brandAvatar}
            alt=''
            class={brandMarkImg}
            onerror="this.style.display='none'"
            loading='eager'
            decoding='async'
          />
        )
      }
    </span>
    <span class={brandText}>
      <span class={brandNameStyle}>{brandName}</span>
      <span class={brandRoleStyle}>{brandRole}</span>
    </span>
  </a>

  <nav class={nav} aria-label='주 메뉴'>
    <a href='/' class={navLink} aria-current={current('/')}>
      Home
    </a>
    <a href='/articles' class={navLink} aria-current={current('/articles')}>
      Articles
      {counts.articles !== undefined && <span class={navCount}>{counts.articles}</span>}
    </a>
    <a href='/notes' class={navLink} aria-current={current('/notes')}>
      Notes
      {counts.notes !== undefined && <span class={navCount}>{counts.notes}</span>}
    </a>
    <a href='/projects' class={navLink} aria-current={current('/projects')}>
      Projects
      {counts.projects !== undefined && <span class={navCount}>{counts.projects}</span>}
    </a>
    <a href='/tags' class={navLink} aria-current={current('/tags')}>Tags</a>
    <a href='/about' class={navLink} aria-current={current('/about')}>About</a>
    <a href='/resume' class={navLink} aria-current={current('/resume')}>Resume</a>
  </nav>

  {
    series.length > 0 && (
      <div class={seriesSection}>
        <div class={seriesTitle}>Series</div>
        {series.map((s) => (
          <a href={`/series/${s.slug}`} class={seriesLink} aria-current={seriesCurrent(s.slug)}>
            <span>{s.name}</span>
            <span class={seriesCount}>{s.count}</span>
          </a>
        ))}
      </div>
    )
  }

  <footer class={railFooter}>
    <slot name='theme-toggle' />
    <a href='/rss.xml' class={footerLink}>RSS</a>
    <a href='/feed' class={footerLink}>Feed</a>
  </footer>
</aside>
