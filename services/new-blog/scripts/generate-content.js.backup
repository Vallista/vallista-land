  }

  // 2021년 회고 특별 처리
  if (slug === '2021-year-retrospective') {
    // "2020년, 우수사원을 받다" 섹션에 이미지 추가
    if (result.includes('## 2020년, 우수사원을 받다') && !result.includes('![우수사원 패]')) {
      result = result.replace(
        '## 2020년, 우수사원을 받다',
        '## 2020년, 우수사원을 받다\n\n![우수사원 패](assets/1.jpeg)'
      )
    }

    // 이벤트 페이지 메이커 설명 부분에 이미지 추가
    if (result.includes('이벤트 페이지 메이커는 현재 배민에서 운영되고 있는 만다오가 만들어지기 이전, B마트의 마케터가 수기로 마크업을 하던 형태를 개선하기 위해 만들어진 에디터입니다.') && !result.includes('![이벤트페이지메이커 오픈]')) {
      result = result.replace(
        '이벤트 페이지 메이커는 현재 배민에서 운영되고 있는 만다오가 만들어지기 이전, B마트의 마케터가 수기로 마크업을 하던 형태를 개선하기 위해 만들어진 에디터입니다.',
        '이벤트 페이지 메이커는 현재 배민에서 운영되고 있는 만다오가 만들어지기 이전, B마트의 마케터가 수기로 마크업을 하던 형태를 개선하기 위해 만들어진 에디터입니다.\n\n![이벤트페이지메이커 오픈](assets/2.png)'
      )
    }

    // 마케터 반응 부분에 이미지 추가
    if (result.includes('이벤트 페이지 메이커 오픈을 진행하고 나서, 마케터분들의 반응이 뜨거웠습니다.') && !result.includes('![마케터분들의 반응]')) {
      result = result.replace(
        '이벤트 페이지 메이커 오픈을 진행하고 나서, 마케터분들의 반응이 뜨거웠습니다.',
        '이벤트 페이지 메이커 오픈을 진행하고 나서, 마케터분들의 반응이 뜨거웠습니다.\n\n![마케터분들의 반응](assets/3.png)'
      )
    }

    // 데일리 리포트 섹션에 이미지 추가
    if (result.includes('3년동안 지속적으로 퍼포먼스는 올라갔고, 어떤 일을 했는지 로깅을 해두니 과거에 어떤 일을 언제 했는지 회고하기 쉬웠습니다.') && !result.includes('![3년간 데일리 리포트]')) {
      result = result.replace(
        '3년동안 지속적으로 퍼포먼스는 올라갔고, 어떤 일을 했는지 로깅을 해두니 과거에 어떤 일을 언제 했는지 회고하기 쉬웠습니다.',
        '3년동안 지속적으로 퍼포먼스는 올라갔고, 어떤 일을 했는지 로깅을 해두니 과거에 어떤 일을 언제 했는지 회고하기 쉬웠습니다.\n\n![3년간 데일리 리포트](assets/19.png)'
      )
    }

    // 데일리 리포트 상세 이미지 추가
    if (result.includes('<center>3년간 유지된 데일리 리포트</center>') && !result.includes('![데일리 리포트]')) {
      result = result.replace(
        '<center>3년간 유지된 데일리 리포트</center>',
        '<center>3년간 유지된 데일리 리포트</center>\n\n![데일리 리포트](assets/18.png)'
      )
    }
  }

  // 2020년 상반기 회고 특별 처리
  if (slug === '2020-year-first-half-retrospective') {
    // "협업" 섹션에 이미지 추가
    if (result.includes('### 협업') && !result.includes('![1]')) {
      result = result.replace(
        '### 협업',
        '### 협업\n\n![1](./assets/1.png)'
      )
    }

