{
  "name": "@vallista/new-blog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run generate-content && vite",
    "dev:drafts": "INCLUDE_DRAFTS=1 npm run generate-content && vite",
    "build": "npm run generate-content && npm run generate-favicon && vite build && npm run generate-seo && npm run copy-404",
    "generate-favicon": "node scripts/generate-favicon.js",
    "copy-404": "node scripts/copy-404.js",
    "build:check": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "generate-content": "node scripts/generate-content.js",
    "generate-seo": "node scripts/generate-seo.js",
    "deploy": "pnpm build && node scripts/deploy.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.74.4",
    "@vallista/design-system": "workspace:*",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "giscus": "^1.6.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^9.0.1",
    "react-router": "^7.4.0",
    "react-router-dom": "^7.8.0",
    "react-syntax-highlighter": "^15.5.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx-frontmatter": "^5.1.0",
    "remark-rehype": "^11.1.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/react-helmet": "^6.1.5",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@vanilla-extract/vite-plugin": "^5.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.8",
    "chalk": "4.1.2",
    "esbuild": "^0.25.1",
    "eslint": "^9.21.0",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "gh-pages": "^3.2.3",
    "globals": "^15.15.0",
    "prettier": "^3.4.2",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.1.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "resolve": "^1.22.10",
    "sharp": "^0.34.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "unified": "^11.0.5",
    "vite": "^6.2.0",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^2.1.8"
  }
}
