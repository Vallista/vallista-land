{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pensmith",
  "version": "0.0.1",
  "identifier": "com.vallista.pensmith",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5977",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pensmith",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 16 }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "category": "public.app-category.developer-tools"
  }
}
