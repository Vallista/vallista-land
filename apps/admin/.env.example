# Google Analytics 4 - Data API
# 1) Google Cloud Console에서 서비스 계정 생성 후 JSON 키 다운로드
# 2) GA4 속성 관리 > 속성 액세스 관리에서 해당 이메일을 뷰어로 추가
# 3) 아래 두 변수 설정 후 dev 서버 재시작
GA_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# GitHub Actions CI 상태 표시 (상단 진행 바)
# 1) https://github.com/settings/tokens?type=beta 에서 fine-grained PAT 생성
#    Repository access: Vallista/vallista-land
#    Permissions > Repository > Actions: Read-only
# 2) GITHUB_REPO는 비워두면 Vallista/vallista-land 사용
GITHUB_TOKEN=
GITHUB_REPO=
