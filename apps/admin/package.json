{
  "name": "@vallista/admin",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --packages=external --format=esm --outdir=dist-electron --out-extension:.js=.mjs --target=node20",
    "build:icon": "bash scripts/build-icon.sh",
    "dev:app": "concurrently -k -s command-electron -n vite,electron -c cyan,magenta \"vite\" \"wait-on http://localhost:5977 && pnpm build:electron && electron .\"",
    "pack:app": "pnpm build && pnpm build:electron && electron-builder --mac --dir",
    "build:app": "pnpm build && pnpm build:electron && electron-builder --mac"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.3",
    "@google-analytics/data": "^5.2.1",
    "@hono/node-server": "^1.13.7",
    "@uiw/react-codemirror": "^4.23.7",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.18.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.vallista.admin",
    "productName": "vallista admin",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    }
  }
}
