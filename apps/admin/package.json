{
  "name": "@vallista/pensmith",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Pensmith — vallista's personal workshop (Tauri + Vite + React)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "migrate:content": "node scripts/migrate-existing-content.mjs",
    "migrate:content:dry": "node scripts/migrate-existing-content.mjs --dry-run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@vallista/content-core": "workspace:*",
    "@vallista/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/vite-plugin": "^4.0.19",
    "@vitejs/plugin-react": "^4.3.4",
    "gray-matter": "^4.0.3",
    "typescript": "~5.7.2",
    "ulid": "^2.3.0",
    "vite": "^6.0.7"
  }
}
