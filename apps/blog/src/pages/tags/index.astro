---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import Chip from '@vallista/ui/components/Chip.astro'
import { countTags, slugifyTag } from '@lib/tags'
import { tagsGrid } from '../../styles/tag.css'

const published = await getCollection('articles', (a) => !a.data.draft)
const stats = countTags(published)
---

<BaseLayout title='Tags · Vallista Blog'>
  <PageHeader eyebrow='@vallista · tags' title='태그 모음' searchPlaceholder='태그 검색…' />

  <p style='color: var(--ink2); margin: 0 0 32px;'>총 {stats.length}개 태그 · {published.length}개 글</p>

  <div class={tagsGrid}>
    {stats.map((s) => <Chip href={`/tags/${slugifyTag(s.tag)}`}>{`#${s.tag} · ${s.count}`}</Chip>)}
  </div>
</BaseLayout>
