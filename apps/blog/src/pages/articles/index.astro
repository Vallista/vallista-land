---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import PostCard from '@components/PostCard.astro'
import { section, sectionHead, sectionTitle, listGrid } from '../../styles/home.css'

const published = await getCollection('articles', (a) => !a.data.draft)
published.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const counts = { articles: published.length, notes: 0, projects: 0 }
---

<BaseLayout title='Articles · Vallista Blog' counts={counts}>
  <PageHeader eyebrow='@vallista · articles' title='긴 글' />

  <section class={section}>
    <header class={sectionHead}>
      <h2 class={sectionTitle}>{`전체 · ${published.length}개`}</h2>
    </header>
    <div class={listGrid}>
      {
        published.map((entry) => (
          <PostCard
            id={entry.id}
            title={entry.data.title}
            date={entry.data.date}
            tag={entry.data.tag}
            tags={entry.data.tags}
            cover={entry.data.cover}
            image={entry.data.image}
            body={entry.body ?? ''}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
