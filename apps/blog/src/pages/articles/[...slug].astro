---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

import ArticleLayout from '@layouts/ArticleLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('articles', (a) => !a.data.draft)
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }))
}

interface Props {
  entry: CollectionEntry<'articles'>
}

const { entry } = Astro.props
const { Content, headings } = await render(entry)

const tocHeadings = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ depth: h.depth as 2 | 3, slug: h.slug, text: h.text }))

const published = await getCollection('articles', (a) => !a.data.draft)
---

<ArticleLayout entry={entry} headings={tocHeadings}>
  <Content />
</ArticleLayout>
