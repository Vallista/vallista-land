---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

import PostLayout from '@layouts/PostLayout.astro'
import PostHeader from '@components/PostHeader.astro'
import PostNav from '@components/PostNav.astro'
import { normalizeArticleImage } from '@lib/article-image'

export async function getStaticPaths() {
  const entries = await getCollection('notes', (n) => !n.data.draft)
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\/index$/, '') },
    props: { entry }
  }))
}

interface Props {
  entry: CollectionEntry<'notes'>
}

const { entry } = Astro.props
const { data } = entry
const { Content } = await render(entry)

const allNotes = await getCollection('notes', (n) => !n.data.draft)
allNotes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const idx = allNotes.findIndex((n) => n.id === entry.id)
const prev = idx > 0 ? allNotes[idx - 1] : null
const next = idx >= 0 && idx < allNotes.length - 1 ? allNotes[idx + 1] : null

const dateISO = data.date.toISOString()
const dateLabel = dateISO.slice(0, 10).replace(/-/g, '.')
const title = data.title ?? dateLabel
const heroImage = normalizeArticleImage(data.image, entry.id, 'notes')

const chips = data.tags.map((t) => ({ label: `#${t}` }))

function slugOf(id: string): string {
  return id.replace(/\/index$/, '')
}

function labelOf(n: CollectionEntry<'notes'>): string {
  return n.data.title ?? n.data.date.toISOString().slice(0, 10)
}
---

<PostLayout
  pageTitle={`${title} · Vallista Notes`}
  heroImage={heroImage}
  heroAlt={title}
>
  <PostHeader
    slot='header'
    eyebrow='@vallista · notes'
    chips={chips}
    title={title}
    meta={[{ text: dateLabel, datetime: dateISO }]}
  />

  <Content />

  <PostNav
    slot='afterProse'
    ariaLabel='이전/다음 노트'
    prev={prev ? { href: `/notes/${slugOf(prev.id)}`, label: labelOf(prev) } : null}
    next={next ? { href: `/notes/${slugOf(next.id)}`, label: labelOf(next) } : null}
    backHref='/notes'
    backLabel='노트 목록으로'
  />
</PostLayout>
