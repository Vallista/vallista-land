---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import { title } from '../styles/home.css'

const notes = await getCollection('notes', (n) => !n.data.draft)
notes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const articles = await getCollection('articles', (a) => !a.data.draft)
const counts = { articles: articles.length, notes: notes.length, projects: 0 }
---

<BaseLayout title='Notes · Vallista Blog' counts={counts}>
  <div class='eyebrow'>@vallista · notes</div>
  <h1 class={title} style='margin-bottom: 32px;'>짧은 글</h1>

  {
    notes.length === 0 ? (
      <p style='color: var(--ink3);'>아직 작성된 노트가 없습니다.</p>
    ) : (
      <ul style='list-style: none; padding: 0; margin: 0;'>
        {notes.map((n) => (
          <li style='padding: 16px 0; border-bottom: 1px solid var(--line2); display: grid; grid-template-columns: 52px 1fr; gap: 20px;'>
            <time style='font-family: monospace; font-size: 12px; color: var(--ink4);' datetime={n.data.date.toISOString()}>
              {n.data.date.toISOString().slice(5, 10)}
            </time>
            <div set:html={n.body ?? ''} style='font-size: 15.5px; line-height: 1.7;' />
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
