---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import AboutResume from '@components/AboutResume.astro'

const articles = await getCollection('articles', (a) => !a.data.draft)
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<BaseLayout title='Resume · Vallista Blog'>
  <AboutResume initialTab='resume' recentArticles={articles} />
</BaseLayout>
