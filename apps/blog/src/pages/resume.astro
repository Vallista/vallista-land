---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import SocialLinks from '@components/SocialLinks.astro'
import resume from '@configs/resume.json'
import {
  wrap,
  name as nameStyle,
  role as roleStyle,
  bio as bioStyle,
  sectionTitle,
  career,
  careerMeta,
  careerBody,
  careerTitle,
  careerDept,
  careerDescList,
  careerDescItem,
  project,
  projectTitle,
  projectDate,
  list,
  listItem,
  listLink
} from '../styles/resume.css'

const articles = await getCollection('articles', (a) => !a.data.draft)
const counts = { articles: articles.length, notes: 0, projects: 0 }

const socialLinks = [
  { kind: 'github' as const, href: resume.config.github, label: 'GitHub' },
  { kind: 'email' as const, href: `mailto:${resume.config.email}`, label: resume.config.email }
]

type ListSection = { description: string | null; list: { title: string; url: string | null }[] }

const miscSections: Array<{ id: string; title: string; section: ListSection }> = [
  { id: 'speaker', title: resume.speaker.description, section: resume.speaker as unknown as ListSection },
  { id: 'activities', title: resume.activities.description ?? '활동', section: resume.activities },
  { id: 'lectures', title: resume.lectures.description ?? '강의', section: resume.lectures },
  { id: 'awards', title: resume.awards.description ?? '수상', section: resume.awards }
]
---

<BaseLayout title='Resume · Vallista' counts={counts}>
  <div class={wrap}>
    <div class='eyebrow'>@vallista · resume</div>
    <h1 class={nameStyle}>{resume.config.name}</h1>
    <div class={roleStyle}>{resume.config.role}</div>

    {
      resume.config.bio.map((line) => (
        <p class={bioStyle}>
          <Fragment set:html={line} />
        </p>
      ))
    }

    <SocialLinks links={socialLinks} />

    {/* ─── 경력 ─── */}
    <h2 class={sectionTitle}>{resume.careers.title}</h2>
    {
      resume.careers.list.map((c) => (
        <div class={career}>
          <div class={careerMeta}>
            <div>
              {c.startDate} ~ {c.endDate ?? '재직중'}
            </div>
            <div>{c.position}</div>
          </div>
          <div class={careerBody}>
            <h3 class={careerTitle}>{c.name}</h3>
            <p class={careerDept}>{c.department}</p>
            {c.descriptions && c.descriptions.length > 0 && (
              <ul class={careerDescList}>
                {c.descriptions.map((d) => (
                  <li class={careerDescItem}>{d}</li>
                ))}
              </ul>
            )}
            {c.projects &&
              c.projects.map((p) => (
                <div class={project}>
                  <div class={projectTitle}>{p.name}</div>
                  <div class={projectDate}>
                    {p.startDate} ~ {p.endDate ?? '진행중'}
                  </div>
                  {p.descriptions && p.descriptions.length > 0 && (
                    <ul class={careerDescList}>
                      {p.descriptions.map((d) => (
                        <li class={careerDescItem}>{d}</li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
          </div>
        </div>
      ))
    }

    {/* ─── 취미 ─── */}
    {resume.hobby && resume.hobby.list.length > 0 && (
      <>
        <h2 class={sectionTitle}>{resume.hobby.description}</h2>
        <ul class={list}>
          {
            resume.hobby.list.map((h) => (
              <li class={listItem}>
                <strong>{h.title}</strong>
                {h.descriptions && h.descriptions.length > 0 && (
                  <> — {h.descriptions.join(', ')}</>
                )}
              </li>
            ))
          }
        </ul>
      </>
    )}

    {/* ─── 발표/활동/강의/수상 ─── */}
    {
      miscSections.map(
        (s) =>
          s.section.list.length > 0 && (
            <>
              <h2 class={sectionTitle} id={s.id}>
                {s.title}
              </h2>
              <ul class={list}>
                {s.section.list.map((item) => (
                  <li class={listItem}>
                    {item.url ? (
                      <a
                        href={item.url}
                        class={listLink}
                        target='_blank'
                        rel='noopener noreferrer'
                      >
                        {item.title}
                      </a>
                    ) : (
                      item.title
                    )}
                  </li>
                ))}
              </ul>
            </>
          )
      )
    }
  </div>
</BaseLayout>
