---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import AboutResume from '@components/AboutResume.astro'

const articles = await getCollection('articles', (a) => !a.data.draft)
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const counts = { articles: articles.length, notes: 0, projects: 0 }
---

<BaseLayout title='About · Vallista Blog' counts={counts}>
  <AboutResume initialTab='about' recentArticles={articles} />
</BaseLayout>
