---
import { getCollection } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'

const articles = await getCollection('articles', (a) => !a.data.draft)
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const recent = articles.slice(0, 30)
const counts = { articles: articles.length, notes: 0, projects: 0 }
---

<BaseLayout title='Feed · Vallista Blog' counts={counts}>
  <div class='eyebrow'>@vallista · feed</div>
  <h1 style='font-size: 32px; margin: 0 0 8px;'>RSS 구독</h1>
  <p style='color: var(--ink2); margin: 0 0 32px;'>
    <a href='/rss.xml' style='color: var(--accent); border-bottom: 1px solid currentColor;'>/rss.xml</a> 으로
    최신 {recent.length}개의 글을 구독할 수 있습니다.
  </p>

  <ul style='list-style: none; padding: 0; margin: 0;'>
    {
      recent.map((a) => (
        <li style='padding: 12px 0; border-bottom: 1px solid var(--line2); display: flex; gap: 16px;'>
          <time
            datetime={a.data.date.toISOString()}
            style='font-family: monospace; font-size: 12px; color: var(--ink4); width: 100px; flex-shrink: 0;'
          >
            {a.data.date.toISOString().slice(0, 10)}
          </time>
          <a href={`/articles/${a.id}`} style='color: var(--ink); text-decoration: none; font-weight: 500;'>
            {a.data.title}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
