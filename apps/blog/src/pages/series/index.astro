---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import Chip from '@vallista/ui/components/Chip.astro'
import { collectSeries, postsInSeries } from '@lib/series'
import { title } from '../../styles/home.css'
import { section, sectionHead, sectionTitle } from '../../styles/home.css'

const articles = await getCollection('articles', (a) => !a.data.draft)
const seriesList = collectSeries(articles)
const counts = { articles: articles.length, notes: 0, projects: 0 }

const seriesWithPreview = seriesList.map((s) => ({
  ...s,
  preview: postsInSeries(articles, s.name).slice(0, 3)
}))
---

<BaseLayout title='Series · Vallista Blog' counts={counts}>
  <div class='eyebrow'>@vallista · series</div>
  <h1 class={title} style='margin-bottom: 16px;'>시리즈</h1>
  <p style='color: var(--ink2); margin: 0 0 40px;'>
    총 {seriesList.length}개의 시리즈로 이어지는 글을 모았습니다.
  </p>

  {
    seriesWithPreview.length === 0 ? (
      <p style='color: var(--ink3);'>아직 시리즈로 묶인 글이 없습니다.</p>
    ) : (
      <section class={section}>
        <div style='display: grid; grid-template-columns: 1fr; gap: 16px;'>
          {seriesWithPreview.map((s) => (
            <a
              href={`/series/${s.slug}`}
              style='display: block; padding: 24px; border: 1px solid var(--line2); border-radius: 12px; background: var(--bg); text-decoration: none; color: inherit; transition: border-color 120ms, box-shadow 180ms, transform 180ms;'
            >
              <div style='display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12px;'>
                <h2 style='font-size: 20px; font-weight: 600; margin: 0; color: var(--ink);'>
                  {s.name}
                </h2>
                <Chip tone='blue'>{`${s.count}편`}</Chip>
              </div>
              <ul style='list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px;'>
                {s.preview.map((p, idx) => (
                  <li style='display: flex; gap: 10px; align-items: baseline; font-size: 14px; color: var(--ink2); line-height: 1.5;'>
                    <span style='font-family: monospace; font-size: 11px; color: var(--ink4); letter-spacing: 0.04em;'>
                      #{String(idx + 1).padStart(2, '0')}
                    </span>
                    <span>{p.title}</span>
                  </li>
                ))}
                {s.count > s.preview.length && (
                  <li style='font-size: 12px; color: var(--ink4); font-family: monospace; padding-left: 42px;'>
                    외 {s.count - s.preview.length}편 더 보기
                  </li>
                )}
              </ul>
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
