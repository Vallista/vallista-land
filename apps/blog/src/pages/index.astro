---
import { getCollection } from 'astro:content'

import BaseLayout from '@layouts/BaseLayout.astro'
import PostCard from '@components/PostCard.astro'
import Chip from '@vallista/ui/components/Chip.astro'
import Cover from '@vallista/ui/components/Cover.astro'
import Input from '@vallista/ui/components/Input.astro'
import { estimateReadingTime } from '@lib/reading-time'
import { normalizeArticleImage } from '@lib/article-image'
import { resolveDek } from '@lib/excerpt'
import {
  header,
  title,
  searchSlot,
  section,
  sectionHead,
  sectionTitle,
  featuredGrid,
  featuredMeta,
  featuredMetaRow,
  featuredTitle,
  featuredDek as featuredDekStyle,
  listGrid,
  bottomLink
} from '../styles/home.css'

const published = await getCollection('articles', (a) => !a.data.draft)
published.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const featuredEntry = published.find((a) => a.data.featured) ?? published[0]
const restEntries = featuredEntry ? published.filter((a) => a.id !== featuredEntry.id).slice(0, 4) : []

const counts = { articles: published.length, notes: 0, projects: 0 }

const featuredMinutes = featuredEntry ? estimateReadingTime(featuredEntry.body ?? '').minutes : 0
const featuredImage = featuredEntry
  ? normalizeArticleImage(featuredEntry.data.image, featuredEntry.id)
  : undefined
const featuredDek = featuredEntry ? resolveDek(featuredEntry.data, featuredEntry.body, 180) : ''
---

<BaseLayout title='Vallista Blog · 최근에 쓴 글' counts={counts}>
  <header class={header}>
    <div>
      <div class='eyebrow'>@vallista · 글</div>
      <h1 class={title}>최근에 쓴 글</h1>
    </div>
    <div class={searchSlot}>
      <Input type='search' placeholder='글 검색…' icon='search' kbdHint='⌘K' aria-label='글 검색' />
    </div>
  </header>

  {
    featuredEntry && (
      <section class={section}>
        <header class={sectionHead}>
          <h2 class={sectionTitle}>Featured</h2>
        </header>
        <a href={`/articles/${featuredEntry.id}`} class={featuredGrid} style='color: inherit; text-decoration: none;'>
          <Cover kind={featuredEntry.data.cover} ratio='16 / 9' image={featuredImage} alt={featuredEntry.data.title} />
          <div class={featuredMeta}>
            <div class={featuredMetaRow}>
              <Chip tone='blue'>Featured</Chip>
              <Chip>{`Article · ${featuredMinutes} min`}</Chip>
            </div>
            <h3 class={featuredTitle}>{featuredEntry.data.title}</h3>
            {featuredDek && <p class={featuredDekStyle}>{featuredDek}</p>}
            <div class={featuredMetaRow}>
              {featuredEntry.data.tags.slice(0, 3).map((t) => (
                <Chip>{t}</Chip>
              ))}
            </div>
          </div>
        </a>
      </section>
    )
  }

  {
    restEntries.length > 0 && (
      <section class={section}>
        <header class={sectionHead}>
          <h2 class={sectionTitle}>Recent</h2>
        </header>
        <div class={listGrid}>
          {restEntries.map((entry) => (
            <PostCard
              id={entry.id}
              title={entry.data.title}
              date={entry.data.date}
              tag={entry.data.tag}
              tags={entry.data.tags}
              cover={entry.data.cover}
              image={entry.data.image}
              body={entry.body ?? ''}
            />
          ))}
        </div>
        <a href='/articles' class={bottomLink}>Articles →</a>
      </section>
    )
  }
</BaseLayout>
