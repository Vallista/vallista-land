---
import { row, link, icon } from './SocialLinks.css'

interface SocialLink {
  kind: 'github' | 'tistory' | 'email' | 'rss' | 'link'
  href: string
  label: string
}

interface Props {
  links: SocialLink[]
  class?: string
}

const { links, class: className } = Astro.props
const classes = [row, className].filter(Boolean).join(' ')
---

<div class={classes}>
  {
    links.map((l) => (
      <a
        href={l.href}
        class={link}
        target={l.kind === 'email' ? undefined : '_blank'}
        rel={l.kind === 'email' ? undefined : 'noopener noreferrer'}
      >
        {l.kind === 'github' && (
          <svg
            class={icon}
            width='16'
            height='16'
            viewBox='0 0 16 16'
            fill='currentColor'
            aria-hidden='true'
          >
            <path d='M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z' />
          </svg>
        )}
        {l.kind === 'tistory' && (
          <svg
            class={icon}
            width='16'
            height='16'
            viewBox='0 0 16 16'
            fill='currentColor'
            aria-hidden='true'
          >
            <circle cx='4.5' cy='8' r='2.2' />
            <circle cx='11.5' cy='4.5' r='2.2' />
            <circle cx='11.5' cy='11.5' r='2.2' />
          </svg>
        )}
        {l.kind === 'email' && (
          <svg
            class={icon}
            width='16'
            height='16'
            viewBox='0 0 16 16'
            fill='none'
            stroke='currentColor'
            stroke-width='1.4'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
          >
            <rect x='2' y='3.5' width='12' height='9' rx='1.5' />
            <path d='m2.5 4 5.5 4 5.5-4' />
          </svg>
        )}
        {l.kind === 'rss' && (
          <svg
            class={icon}
            width='16'
            height='16'
            viewBox='0 0 16 16'
            fill='none'
            stroke='currentColor'
            stroke-width='1.6'
            stroke-linecap='round'
            aria-hidden='true'
          >
            <path d='M3 12.5h.01' />
            <path d='M3 8a5 5 0 0 1 5 5' />
            <path d='M3 3a10 10 0 0 1 10 10' />
          </svg>
        )}
        {l.kind === 'link' && (
          <svg
            class={icon}
            width='16'
            height='16'
            viewBox='0 0 16 16'
            fill='none'
            stroke='currentColor'
            stroke-width='1.4'
            stroke-linecap='round'
            stroke-linejoin='round'
            aria-hidden='true'
          >
            <path d='M6 10a3 3 0 0 0 4.5.5l2-2a3 3 0 0 0-4.5-4l-1 1' />
            <path d='M10 6a3 3 0 0 0-4.5-.5l-2 2a3 3 0 0 0 4.5 4l1-1' />
          </svg>
        )}
        <span>{l.label}</span>
      </a>
    ))
  }
</div>
