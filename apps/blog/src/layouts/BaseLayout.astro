---
import { getCollection } from 'astro:content'

import { lightTheme, darkTheme } from '@vallista/ui'
import NavRail from '@vallista/ui/components/NavRail.astro'
import DarkModeToggle from '@vallista/ui/components/DarkModeToggle.astro'
import Footer from '@vallista/ui/components/Footer.astro'
import MobileMenu from '@vallista/ui/components/MobileMenu.astro'

import SearchPalette from '@components/SearchPalette.astro'
import { collectSeries } from '@lib/series'

const allArticles = await getCollection('articles', (a) => !a.data.draft)
const seriesList = collectSeries(allArticles)

const footerGroups = [
  {
    title: '사이트 맵',
    links: [
      { label: '홈', href: '/' },
      { label: '아티클', href: '/articles' },
      { label: '노트', href: '/notes' },
      { label: '프로젝트', href: '/projects' },
      { label: '태그', href: '/tags' },
      { label: '시리즈', href: '/series' }
    ]
  },
  {
    title: '관련 사이트',
    links: [
      { label: 'GitHub', href: 'https://github.com/vallista', external: true },
      { label: '이전 블로그', href: 'https://vallista.tistory.com', external: true },
      { label: '우아한형제들 채용', href: 'https://career.woowahan.com/', external: true },
      { label: '우아한형제들 기술블로그', href: 'https://techblog.woowahan.com/', external: true }
    ]
  }
]

import '@vallista/ui/global.css'
import '../styles/app.css'

interface Props {
  title: string
  description?: string
  image?: string | null
  ogType?: 'website' | 'article'
  counts?: {
    articles?: number
    notes?: number
    projects?: number
  }
}

const { title, description, image, ogType = 'website', counts } = Astro.props
const path = new URL(Astro.request.url).pathname
const siteDescription = description ?? 'Vallista의 기술 블로그 — 프론트엔드·디자인 시스템·도구에 대한 글'
const ogImage = image ? new URL(image, Astro.url).toString() : new URL('/favicon/favicon-512x512.png', Astro.url).toString()

const GA_ID = import.meta.env.PUBLIC_GA_ID
const isGAEnabled = import.meta.env.PROD && !!GA_ID
---

<!doctype html>
<html lang='ko-KR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <!-- MPA View Transitions: 같은 origin 간 navigation에 브라우저가 자동 crossfade 적용
         (Chrome 126+, Safari 18+). 미지원 브라우저는 아래 body fade-in 애니메이션으로 fallback -->
    <meta name='view-transition' content='same-origin' />
    <link rel='icon' type='image/svg+xml' href='/favicon/favicon.svg' />
    <link rel='alternate icon' href='/favicon/favicon.ico' />
    <link rel='apple-touch-icon' sizes='180x180' href='/favicon/apple-touch-icon.png' />
    <link rel='manifest' href='/favicon/manifest.json' />
    <meta name='theme-color' content='#ffffff' />
    <title>{title}</title>
    <meta name='description' content={siteDescription} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={siteDescription} />
    <meta property='og:type' content={ogType} />
    <meta property='og:url' content={Astro.url.href} />
    <meta property='og:image' content={ogImage} />
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={siteDescription} />
    <meta name='twitter:image' content={ogImage} />

    <!-- FOUC 방지 + 테마 토글 전역 함수 정의. 매 페이지 렌더마다 lightClass/darkClass
         최신값을 window에 주입하여 어떤 시점에 onclick 호출되어도 안전하게 동작. -->
    <script is:inline define:vars={{ lightClass: lightTheme, darkClass: darkTheme }}>
      ;(function () {
        var KEY = 'theme'
        function currentMode() {
          var v = localStorage.getItem(KEY)
          return v === 'light' || v === 'dark' || v === 'system' ? v : 'system'
        }
        function resolve(mode) {
          if (mode !== 'system') return mode
          return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        }
        function apply(mode) {
          var dark = resolve(mode) === 'dark'
          var root = document.documentElement
          root.classList.toggle(window.__vallistaDarkClass || darkClass, dark)
          root.classList.toggle(window.__vallistaLightClass || lightClass, !dark)
          root.classList.toggle('theme-dark', dark)
          root.classList.toggle('theme-light', !dark)
        }
        function cycle() {
          // 현재 화면에 실제로 적용된 테마(system의 경우 resolved 결과)를 기준으로
          // 반대로 토글. "다크면 라이트, 라이트면 다크" — 한 번만 누르면 전환.
          var resolved = resolve(currentMode())
          var next = resolved === 'dark' ? 'light' : 'dark'
          localStorage.setItem(KEY, next)
          apply(next)
        }

        window.__vallistaLightClass = lightClass
        window.__vallistaDarkClass = darkClass
        window.__vallistaThemeApply = apply
        window.__vallistaThemeCycle = cycle

        apply(currentMode())

        if (!window.__vallistaThemeMediaBound) {
          window.__vallistaThemeMediaBound = true
          matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
            if (currentMode() === 'system') apply('system')
          })
        }
      })()
    </script>

    {isGAEnabled && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || []
          function gtag() { dataLayer.push(arguments) }
          window.gtag = gtag
          gtag('js', new Date())
          // 초기 로드는 자동 PV. SPA 전환은 아래 navigate() 에서 수동으로 쏨.
          gtag('config', GA_ID)
        </script>
      </Fragment>
    )}

    <!-- Pretendard Variable -->
    <link rel='stylesheet' as='style' crossorigin
      href='https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css' />

    <!-- JetBrains Mono -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap' />
  </head>
  <body>
    <a href='#main' class='skip-link'>본문으로 바로 가기</a>
    <MobileMenu
      path={path}
      counts={counts}
      brandAvatar='https://avatars.githubusercontent.com/u/6455767?v=4'
      series={seriesList}
    >
      <DarkModeToggle slot='theme-toggle' />
    </MobileMenu>
    <div class='layout'>
      <NavRail
        path={path}
        counts={counts}
        brandAvatar='https://avatars.githubusercontent.com/u/6455767?v=4'
        series={seriesList}
      >
        <DarkModeToggle slot='theme-toggle' />
      </NavRail>
      <main id='main' class='layout__main'>
        <div id='main-content' class='page-body page-fade'>
          <slot />
        </div>
        <Footer groups={footerGroups} />
      </main>
    </div>
    <!-- main 바깥 body 직계. transform 컨텍스트에 묶이지 않아서 position:fixed 가 viewport 기준으로 동작.
         SPA 네비 시 main-content 와 함께 교체 대상이 되도록 id 컨테이너로 감쌈. -->
    <div id='page-overlay'>
      <slot name='overlay' />
    </div>
    <SearchPalette />

    <!-- 커스텀 SPA 네비게이션: 사이드바와 CSS는 그대로 유지하고 main-content 만 교체.
         Astro ClientRouter 대안 — vanilla-extract head swap 이슈 회피 + 사이드바 persist. -->
    <script is:inline>
      ;(function () {
        if (window.__vallistaSpaNav) return
        window.__vallistaSpaNav = true

        var busy = false
        var LEAVE_MS = 140

        function getMain() {
          return document.getElementById('main-content')
        }

        function shouldIntercept(e, a) {
          if (busy || e.defaultPrevented) return false
          if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return false
          if (!a || !a.href) return false
          if (a.target && a.target !== '_self') return false
          if (a.hasAttribute('download')) return false
          var href = a.getAttribute('href')
          if (!href || href.charAt(0) === '#') return false
          var url
          try { url = new URL(a.href, location.href) } catch (_) { return false }
          if (url.origin !== location.origin) return false
          if (url.protocol !== 'http:' && url.protocol !== 'https:') return false
          if (url.pathname === location.pathname && url.search === location.search) return false
          // 정적 자산은 intercept 하지 않음
          if (/\.(xml|rss|json|png|jpg|jpeg|gif|webp|svg|pdf|zip)$/i.test(url.pathname)) return false
          return true
        }

        async function navigate(url) {
          var main = getMain()
          if (!main) { location.href = url.href; return }
          busy = true
          main.classList.add('is-leaving')
          // 사용자가 leave 애니메이션을 보는 동안 fetch 병렬 실행
          var fetchP = fetch(url.href, { credentials: 'same-origin' }).then(function (r) { return r.text() })
          var delayP = new Promise(function (resolve) { setTimeout(resolve, LEAVE_MS) })
          try {
            var results = await Promise.all([fetchP, delayP])
            var html = results[0]
            var doc = new DOMParser().parseFromString(html, 'text/html')
            var newMain = doc.getElementById('main-content')
            if (!newMain) { location.href = url.href; return }

            document.title = doc.title

            // head의 새 스타일만 보완적으로 추가 (기존 스타일은 유지). 같은 href면 중복 추가 안 함.
            var existingHrefs = new Set()
            document.querySelectorAll('link[rel="stylesheet"][href]').forEach(function (l) { existingHrefs.add(l.href) })
            doc.querySelectorAll('link[rel="stylesheet"][href]').forEach(function (l) {
              if (!existingHrefs.has(l.href)) {
                var clone = document.createElement('link')
                clone.rel = 'stylesheet'
                clone.href = l.getAttribute('href')
                document.head.appendChild(clone)
              }
            })

            // NavRail의 aria-current 업데이트만 따로 처리 (사이드바 DOM은 유지)
            var newPath = url.pathname
            document.querySelectorAll('aside a[href]').forEach(function (a) {
              var ah = a.getAttribute('href') || ''
              var isCurrent = false
              if (ah === '/') isCurrent = newPath === '/'
              else isCurrent = newPath === ah || newPath.indexOf(ah + '/') === 0
              if (isCurrent) a.setAttribute('aria-current', 'page')
              else a.removeAttribute('aria-current')
            })

            // main-content DOM 교체
            main.replaceWith(newMain)

            function rerunScripts(root) {
              root.querySelectorAll('script').forEach(function (oldS) {
                var s = document.createElement('script')
                for (var i = 0; i < oldS.attributes.length; i++) {
                  var a = oldS.attributes[i]
                  s.setAttribute(a.name, a.value)
                }
                s.textContent = oldS.textContent
                oldS.parentNode.replaceChild(s, oldS)
              })
            }

            // 새 main에 있는 script 태그 실행
            rerunScripts(newMain)

            // overlay(예: TOC) 교체 — main 바깥이지만 페이지별 콘텐츠이므로 같이 갱신
            var overlay = document.getElementById('page-overlay')
            var newOverlay = doc.getElementById('page-overlay')
            if (overlay && newOverlay) {
              overlay.replaceWith(newOverlay)
              rerunScripts(newOverlay)
            }

            history.pushState({}, '', url.href)
            window.scrollTo(0, 0)

            // SPA 전환 추적: full reload 가 아니므로 수동으로 page_view 를 보낸다.
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'page_view', {
                page_path: url.pathname + url.search,
                page_title: document.title,
                page_location: url.href
              })
            }

            document.dispatchEvent(new CustomEvent('vallista:page-load'))
          } catch (err) {
            location.href = url.href
          } finally {
            busy = false
          }
        }

        document.addEventListener('click', function (e) {
          var a = e.target.closest ? e.target.closest('a[href]') : null
          if (!shouldIntercept(e, a)) return
          e.preventDefault()
          var url = new URL(a.href, location.href)
          navigate(url)
        })

        window.addEventListener('popstate', function () {
          location.reload()
        })
      })()
    </script>
  </body>
</html>
