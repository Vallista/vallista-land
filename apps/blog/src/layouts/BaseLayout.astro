const allArticles = await getCollection('articles', (a) => !a.data.draft)
const seriesList = collectSeries(allArticles)

const footerGroups = [
  {
    title: 'š˜šÇÚ¡ ŠÏç',
    links: [
      { label: 'Ú', href: '/' },
      { label: 'šÚ¯ÚÇ', href: '/articles' },
      { label: 'Š¡Ú¡', href: '/notes' },
      { label: 'ÚŠÀš Ú¡', href: '/projects' },
      { label: 'Úõñ¡', href: '/tags' },
      { label: 'šŠÎ˜šÎ', href: '/series' }
    ]
  },
  {
    title: 'õÇŠ ´ š˜šÇÚ¡',
    links: [
      { label: 'GitHub', href: 'https://github.com/vallista', external: true },
      { label: 'šÇš  Š¡ŠÀõñ¡', href: 'https://vallista.tistory.com', external: true },
      { label: 'š¯šÚÚš ŠÊ šÝšˋ', href: 'https://career.woowahan.com/', external: true },
      { label: 'š¯šÚÚš ŠÊ õ¡¯š Š¡ŠÀõñ¡', href: 'https://techblog.woowahan.com/', external: true }
    ]
  }
]

import '@vallista/ui/global.css'
import '../styles/app.css'

interface Props {
  title: string
  description?: string
  counts?: {
    articles?: number
    notes?: number
    projects?: number
  }
}

const { title, description, counts } = Astro.props
const path = new URL(Astro.request.url).pathname
const siteDescription = description ?? 'Vallistaš õ¡¯š  Š¡ŠÀõñ¡ ã ÚŠÀ Ú¡šŠôñŠšš¡ ššÊÚôñŠõç˜š ŠÚ õ¡'
---

<!doctype html>
<html lang='ko-KR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <!-- MPA View Transitions: õ¯š origin õ¯ navigationš Š¡Š¥š¯š õ¯ šŠ crossfade š šˋ
         (Chrome 126+, Safari 18+). Š₤¡šÏš Š¡Š¥š¯š Š šŠ body fade-in š ŠŠˋšÇšš¥ŠÀ fallback -->
    <meta name='view-transition' content='same-origin' />
    <link rel='icon' type='image/svg+xml' href='/favicon/favicon.svg' />
    <link rel='alternate icon' href='/favicon/favicon.ico' />
    <link rel='apple-touch-icon' sizes='180x180' href='/favicon/apple-touch-icon.png' />
    <link rel='manifest' href='/favicon/manifest.json' />
    <meta name='theme-color' content='#ffffff' />
    <title>{title}</title>
    <meta name='description' content={siteDescription} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={siteDescription} />
    <meta property='og:type' content='website' />
    <meta property='og:url' content={Astro.url.href} />

    <!-- FOUC Š¯ˋšÏ + ÚŠÏ Ú õ¡ š šÙ Ú´š š š. ŠÏÊ ÚšÇšÏ Š ŠŠÏŠÊ lightClass/darkClass
         šçš õ¯š windowš šÈ¥šÚš˜ šÇŠÊ šš š onclick Ú¡šÑŠšÇŠ šš Úõý Šš. -->
    <script is:inline define:vars={{ lightClass: lightTheme, darkClass: darkTheme }}>
      ;(function () {
        var KEY = 'theme'
        function currentMode() {
          var v = localStorage.getItem(KEY)
          return v === 'light' || v === 'dark' || v === 'system' ? v : 'system'
        }
        function resolve(mode) {
          if (mode !== 'system') return mode
          return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        }
        function apply(mode) {
          var dark = resolve(mode) === 'dark'
          var root = document.documentElement
          root.classList.toggle(window.__vallistaDarkClass || darkClass, dark)
          root.classList.toggle(window.__vallistaLightClass || lightClass, !dark)
          root.classList.toggle('theme-dark', dark)
          root.classList.toggle('theme-light', !dark)
        }
        function cycle() {
          // Úš˜ ÚŠˋÇš šÊš ŠÀ š šˋŠ ÚŠÏ(systemš õý§š¯ resolved õý¯õ°¥)ŠË¥ õ¡¯šÊš¥ŠÀ
          // Š¯ŠŠÀ Ú õ¡. "ŠÊÚ˜ŠˋÇ Š¥šÇÚ¡, Š¥šÇÚ¡ŠˋÇ ŠÊÚ˜" ã Ú ŠýŠÏ ŠŠËÇŠˋÇ š Ú.
          var resolved = resolve(currentMode())
          var next = resolved === 'dark' ? 'light' : 'dark'
          localStorage.setItem(KEY, next)
          apply(next)
        }

        window.__vallistaLightClass = lightClass
        window.__vallistaDarkClass = darkClass
        window.__vallistaThemeApply = apply
        window.__vallistaThemeCycle = cycle

        apply(currentMode())

        if (!window.__vallistaThemeMediaBound) {
          window.__vallistaThemeMediaBound = true
          matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
            if (currentMode() === 'system') apply('system')
          })
        }
      })()
    </script>

    <!-- Pretendard Variable -->
    <link rel='stylesheet' as='style' crossorigin
      href='https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css' />

    <!-- JetBrains Mono -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap' />
  </head>
  <body>
    <a href='#main' class='skip-link'>Š°¡Š˜¡š¥ŠÀ Š¯ŠÀ õ¯õ¡¯</a>
    <MobileMenu
      path={path}
      counts={counts}
      brandAvatar='https://avatars.githubusercontent.com/u/6455767?v=4'
      series={seriesList}
    >
      <DarkModeToggle slot='theme-toggle' />
    </MobileMenu>
    <div class='layout'>
      <NavRail
        path={path}
        counts={counts}
        brandAvatar='https://avatars.githubusercontent.com/u/6455767?v=4'
        series={seriesList}
      >
        <DarkModeToggle slot='theme-toggle' />
      </NavRail>
      <main id='main' class='layout__main'>
        <div id='main-content' class='page-body page-fade'>
          <slot />
        </div>
        <Footer groups={footerGroups} />
      </main>
    </div>
    <!-- main Š¯õ¿Ë body šÏõ°. transform š£´ÚšÊÚ¡š Š˜ÑšÇšÏ ššš position:fixed õ¯ viewport õ¡¯šÊš¥ŠÀ Šš.
         SPA ŠÊŠ¿ š main-content š Ú´õ£ õçšýÇ ŠššÇ ŠŠŠÀ id š£´ÚšÇŠŠÀ õ¯š. -->
    <div id='page-overlay'>
      <slot name='overlay' />
    </div>
    <SearchPalette />

    <!-- š£ÊšÊÚ SPA ŠÊŠ¿õýšÇš: š˜šÇŠŠ¯š CSSŠ õñ¡ŠŠÀ š šÏÚõ°  main-content ŠÏ õçšýÇ.
         Astro ClientRouter Šš ã vanilla-extract head swap šÇš ÚÚ¥ + š˜šÇŠŠ¯ persist. -->
    <script is:inline>
      ;(function () {
        if (window.__vallistaSpaNav) return
        window.__vallistaSpaNav = true

        var busy = false
        var LEAVE_MS = 140

        function getMain() {
          return document.getElementById('main-content')
        }

        function shouldIntercept(e, a) {
          if (busy || e.defaultPrevented) return false
          if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return false
          if (!a || !a.href) return false
          if (a.target && a.target !== '_self') return false
          if (a.hasAttribute('download')) return false
          var href = a.getAttribute('href')
          if (!href || href.charAt(0) === '#') return false
          var url
          try { url = new URL(a.href, location.href) } catch (_) { return false }
          if (url.origin !== location.origin) return false
          if (url.protocol !== 'http:' && url.protocol !== 'https:') return false
          if (url.pathname === location.pathname && url.search === location.search) return false
          // š š  šš¯š intercept ÚšÏ šš
          if (/\.(xml|rss|json|png|jpg|jpeg|gif|webp|svg|pdf|zip)$/i.test(url.pathname)) return false
          return true
        }

        async function navigate(url) {
          var main = getMain()
          if (!main) { location.href = url.href; return }
          busy = true
          main.classList.add('is-leaving')
          // š˜šˋšõ¯ leave š ŠŠˋšÇšš Š°ÇŠ Šš fetch Š°Š ˜ šÊÚ
          var fetchP = fetch(url.href, { credentials: 'same-origin' }).then(function (r) { return r.text() })
          var delayP = new Promise(function (resolve) { setTimeout(resolve, LEAVE_MS) })
          try {
            var results = await Promise.all([fetchP, delayP])
            var html = results[0]
            var doc = new DOMParser().parseFromString(html, 'text/html')
            var newMain = doc.getElementById('main-content')
            if (!newMain) { location.href = url.href; return }

            document.title = doc.title

            // headš š šÊÚš¥ŠÏ Š°Çšš š¥ŠÀ šÑõ¯ (õ¡¯šÀÇ šÊÚš¥š š šÏ). õ¯š hrefŠˋÇ šÊŠ°ç šÑõ¯ š Ú´.
            var existingHrefs = new Set()
            document.querySelectorAll('link[rel="stylesheet"][href]').forEach(function (l) { existingHrefs.add(l.href) })
            doc.querySelectorAll('link[rel="stylesheet"][href]').forEach(function (l) {
              if (!existingHrefs.has(l.href)) {
                var clone = document.createElement('link')
                clone.rel = 'stylesheet'
                clone.href = l.getAttribute('href')
                document.head.appendChild(clone)
              }
            })

            // NavRailš aria-current šŠ¯šÇÚ¡ŠÏ Š¯ŠÀ šýŠÎ˜ (š˜šÇŠŠ¯ DOMš š šÏ)
            var newPath = url.pathname
            document.querySelectorAll('aside a[href]').forEach(function (a) {
              var ah = a.getAttribute('href') || ''
              var isCurrent = false
              if (ah === '/') isCurrent = newPath === '/'
              else isCurrent = newPath === ah || newPath.indexOf(ah + '/') === 0
              if (isCurrent) a.setAttribute('aria-current', 'page')
              else a.removeAttribute('aria-current')
            })

            // main-content DOM õçšýÇ
            main.replaceWith(newMain)

            function rerunScripts(root) {
              root.querySelectorAll('script').forEach(function (oldS) {
                var s = document.createElement('script')
                for (var i = 0; i < oldS.attributes.length; i++) {
                  var a = oldS.attributes[i]
                  s.setAttribute(a.name, a.value)
                }
                s.textContent = oldS.textContent
                oldS.parentNode.replaceChild(s, oldS)
              })
            }

            // š mainš šŠ script Úõñ¡ šÊÚ
            rerunScripts(newMain)

            // overlay(š: TOC) õçšýÇ ã main Š¯õ¿ËšÇšÏŠÏ ÚšÇšÏŠ° š§Úš¡ šÇŠ₤ŠÀ õ¯šÇ õ¯Ýš 
            var overlay = document.getElementById('page-overlay')
            var newOverlay = doc.getElementById('page-overlay')
            if (overlay && newOverlay) {
              overlay.replaceWith(newOverlay)
              rerunScripts(newOverlay)
            }

            history.pushState({}, '', url.href)
            window.scrollTo(0, 0)

            document.dispatchEvent(new CustomEvent('vallista:page-load'))
          } catch (err) {
            location.href = url.href
          } finally {
            busy = false
          }
        }

        document.addEventListener('click', function (e) {
          var a = e.target.closest ? e.target.closest('a[href]') : null
          if (!shouldIntercept(e, a)) return
          e.preventDefault()
          var url = new URL(a.href, location.href)
          navigate(url)
        })

        window.addEventListener('popstate', function () {
          location.reload()
        })
      })()
    </script>
  </body>
</html>
