---
import { ClientRouter } from 'astro:transitions'
import { lightTheme, darkTheme } from '@vallista/ui'
import NavRail from '@vallista/ui/components/NavRail.astro'
import DarkModeToggle from '@vallista/ui/components/DarkModeToggle.astro'

import SearchPalette from '@components/SearchPalette.astro'

import '@vallista/ui/global.css'
import '../styles/app.css'

interface Props {
  title: string
  description?: string
  counts?: {
    articles?: number
    notes?: number
    projects?: number
  }
}

const { title, description, counts } = Astro.props
const path = new URL(Astro.request.url).pathname
const siteDescription = description ?? 'Vallista의 기술 블로그 — 프론트엔드·디자인 시스템·도구에 대한 글'
---

<!doctype html>
<html lang='ko-KR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{title}</title>
    <meta name='description' content={siteDescription} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={siteDescription} />
    <meta property='og:type' content='website' />
    <meta property='og:url' content={Astro.url.href} />

    <!-- FOUC 방지: body 렌더 전 theme class 주입 (lightTheme/darkTheme
         vanilla-extract 해시를 define:vars로 전달) -->
    <script is:inline define:vars={{ lightClass: lightTheme, darkClass: darkTheme }}>
      ;(function () {
        var KEY = 'theme'
        var v = localStorage.getItem(KEY)
        var mode = v === 'light' || v === 'dark' || v === 'system' ? v : 'system'
        var prefersDark = matchMedia('(prefers-color-scheme: dark)').matches
        var dark = mode === 'dark' || (mode === 'system' && prefersDark)
        var root = document.documentElement
        root.classList.add(dark ? darkClass : lightClass)
        root.classList.remove(dark ? lightClass : darkClass)
        root.classList.toggle('theme-dark', dark)
        root.classList.toggle('theme-light', !dark)
      })()
    </script>

    <!-- Pretendard Variable -->
    <link rel='stylesheet' as='style' crossorigin
      href='https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css' />

    <!-- JetBrains Mono -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link rel='stylesheet'
      href='https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap' />

    <ClientRouter />
  </head>
  <body>
    <a href='#main' class='skip-link'>본문으로 바로 가기</a>
    <div class='layout'>
      <NavRail path={path} counts={counts}>
        <DarkModeToggle slot='theme-toggle' lightClass={lightTheme} darkClass={darkTheme} />
      </NavRail>
      <main id='main' class='layout__main'>
        <slot />
      </main>
    </div>
    <SearchPalette />
  </body>
</html>
