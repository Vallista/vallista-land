---
import BaseLayout from './BaseLayout.astro'
import Toc from '@vallista/ui/components/Toc.astro'
import type { TocHeading } from '@vallista/ui/components/Toc.astro'
import { progress, prose } from '../styles/article.css'

interface Props {
  pageTitle: string
  description?: string
  image?: string | null
  ogType?: 'website' | 'article'
  heroImage?: string | null
  heroAlt?: string
  counts: { articles?: number; notes?: number; projects?: number }
  showProgress?: boolean
  headings?: TocHeading[]
}

const {
  pageTitle,
  description,
  image,
  ogType = 'article',
  heroImage,
  heroAlt = '',
  counts,
  showProgress = false,
  headings
} = Astro.props
---

<BaseLayout
  title={pageTitle}
  description={description}
  image={image}
  ogType={ogType}
  counts={counts}
>
  {showProgress && <div class={progress} data-progress></div>}

  <slot name='header' />
  <slot name='beforeProse' />

  <article class={prose}>
    {
      heroImage && (
        <figure class='img-card'>
          <img
            src={heroImage}
            alt={heroAlt}
            loading='eager'
            decoding='async'
            onload="this.closest('.img-card').classList.add('is-loaded')"
            onerror="this.closest('.img-card').classList.add('is-error')"
          />
        </figure>
      )
    }
    <slot />
  </article>

  <slot name='afterProse' />

  {headings && <Toc slot='overlay' headings={headings} />}

  {showProgress && (
    <script>
      function setupProgress(): void {
        const bar = document.querySelector<HTMLElement>('[data-progress]')
        if (!bar) return
        const on = (): void => {
          const h = document.documentElement
          const max = h.scrollHeight - h.clientHeight
          const pct = max > 0 ? Math.min(100, (h.scrollTop / max) * 100) : 0
          bar.style.width = `${pct}%`
        }
        let ticking = false
        const onScroll = (): void => {
          if (ticking) return
          ticking = true
          requestAnimationFrame(() => {
            on()
            ticking = false
          })
        }
        addEventListener('scroll', onScroll, { passive: true })
        on()
      }

      setupProgress()
      document.addEventListener('astro:page-load', setupProgress)
      document.addEventListener('vallista:page-load', setupProgress)
    </script>
  )}
</BaseLayout>
