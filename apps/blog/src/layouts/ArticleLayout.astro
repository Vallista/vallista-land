---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

import PostLayout from './PostLayout.astro'
import type { TocHeading } from '@vallista/ui/components/Toc.astro'
import PostHeader from '@components/PostHeader.astro'
import PostNav from '@components/PostNav.astro'
import SeriesWidget from '@components/SeriesWidget.astro'
import { estimateReadingTime } from '@lib/reading-time'
import { seriesForEntry } from '@lib/series'
import { normalizeArticleImage } from '@lib/article-image'

interface Props {
  entry: CollectionEntry<'articles'>
  headings: TocHeading[]
}

const { entry, headings } = Astro.props
const { data, body } = entry
const { minutes, words } = estimateReadingTime(body ?? '')
const dateLabel = data.date.toISOString().slice(0, 10).replace(/-/g, '.')

const allArticles = await getCollection('articles', (a) => !a.data.draft)
allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const series = seriesForEntry(allArticles, entry)
const ogImage = normalizeArticleImage(data.image, entry.id)

const idx = allArticles.findIndex((a) => a.id === entry.id)
const prev = idx > 0 ? allArticles[idx - 1] : null
const next = idx >= 0 && idx < allArticles.length - 1 ? allArticles[idx + 1] : null

const chips: Array<{ label: string; tone?: 'neutral' | 'blue' }> = [{ label: data.tag }]
if (data.series) {
  const seriesLabel =
    typeof data.series === 'string'
      ? data.series
      : data.series.name ?? data.series.slug ?? '시리즈'
  chips.push({ label: seriesLabel, tone: 'blue' })
}
---

<PostLayout
  pageTitle={`${data.title} · Vallista Blog`}
  description={data.dek || data.description}
  image={ogImage}
  ogType='article'
  heroImage={ogImage}
  heroAlt={data.title}
  showProgress
  headings={headings}
>
  <PostHeader
    slot='header'
    eyebrow='@vallista · articles'
    chips={chips}
    title={data.title}
    dek={data.dek}
    meta={[
      { text: dateLabel, datetime: data.date.toISOString() },
      { text: `${minutes} min read` },
      { text: `${words.toLocaleString()} words` }
    ]}
  />

  {series && (
    <SeriesWidget slot='beforeProse' name={series.name} slug={series.slug} posts={series.posts} currentId={entry.id} />
  )}

  <slot />

  <PostNav
    slot='afterProse'
    ariaLabel='이전/다음 아티클'
    prev={prev ? { href: `/articles/${prev.id}`, label: prev.data.title } : null}
    next={next ? { href: `/articles/${next.id}`, label: next.data.title } : null}
    backHref='/articles'
    backLabel='아티클 목록으로'
  />
</PostLayout>
