{
  "name": "@vallista/blog-astro",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-assets": "node scripts/copy-article-assets.mjs",
    "dev": "node scripts/copy-article-assets.mjs && astro dev",
    "build": "node scripts/copy-article-assets.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "type-check": "astro check",
    "deploy": "pnpm build && node scripts/deploy.mjs",
    "deploy:only": "node scripts/deploy.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.3",
    "@astrojs/rss": "^4.0.10",
    "@astrojs/sitemap": "^3.2.1",
    "@vallista/markdown": "workspace:*",
    "@vallista/ui": "workspace:*",
    "@vanilla-extract/css": "^1.17.4",
    "astro": "^5.1.1",
    "pagefind": "^1.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@vanilla-extract/vite-plugin": "^5.1.1",
    "typescript": "~5.7.2"
  }
}
