{
  "name": "root",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "~5.6.2"
  },
  "scripts": {
    "build:packages": "pnpm --filter './packages/**' run build",
    "dev": "pnpm --filter @vallista/blog-astro run dev",
    "build": "pnpm --filter @vallista/blog-astro run build",
    "preview": "pnpm --filter @vallista/blog-astro run preview",
    "check": "pnpm --filter @vallista/blog-astro run check",
    "deploy": "pnpm --filter @vallista/blog-astro run deploy",
    "dev:blog": "pnpm --filter @vallista/blog-astro run dev",
    "build:blog": "pnpm --filter @vallista/blog-astro run build",
    "preview:blog": "pnpm --filter @vallista/blog-astro run preview",
    "check:blog": "pnpm --filter @vallista/blog-astro run check",
    "deploy:blog": "pnpm --filter @vallista/blog-astro run deploy",
    "dev:pensmith": "pnpm --filter @vallista/pensmith run tauri:dev",
    "build:pensmith": "pnpm --filter @vallista/pensmith run tauri:build",
    "type-check:pensmith": "pnpm --filter @vallista/pensmith run type-check",
    "migrate:content": "pnpm --filter @vallista/pensmith run migrate:content",
    "migrate:content:dry": "pnpm --filter @vallista/pensmith run migrate:content:dry"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged --verbose"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "eslint --quiet --fix"
    ],
    "*.{json,md,html,js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  }
}
