{
  "name": "root",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "~5.6.2"
  },
  "scripts": {
    "watch:ds": "pnpm --filter @vallista/design-system run watch",
    "publish:ds": "pnpm --filter @vallista/design-system run publish",
    "build:ds": "pnpm --filter @vallista/design-system run build",
    "build:packages": "pnpm --filter './packages/**' run build",
    "storybook": "pnpm --filter @vallista/design-system run storybook",
    "build-storybook": "pnpm --filter @vallista/design-system run build-storybook",
    "dev:blog": "pnpm --filter @vallista/blog-astro run dev",
    "build:blog": "pnpm --filter @vallista/blog-astro run build",
    "preview:blog": "pnpm --filter @vallista/blog-astro run preview",
    "check:blog": "pnpm --filter @vallista/blog-astro run check",
    "deploy:blog": "pnpm --filter @vallista/blog-astro run deploy",
    "dev:new-blog": "pnpm --filter @vallista/new-blog run dev",
    "build:new-blog": "pnpm --filter @vallista/new-blog run build",
    "deploy:new-blog": "pnpm --filter @vallista/new-blog run deploy",
    "generate-content:new-blog": "pnpm --filter @vallista/new-blog run generate-content",
    "preview:new-blog": "pnpm --filter @vallista/new-blog run preview",
    "lint:new-blog": "pnpm --filter @vallista/new-blog run lint",
    "lint:fix:new-blog": "pnpm --filter @vallista/new-blog run lint:fix",
    "type-check:new-blog": "pnpm --filter @vallista/new-blog run type-check",
    "test:new-blog": "pnpm --filter @vallista/new-blog run test",
    "test:ui:new-blog": "pnpm --filter @vallista/new-blog run test:ui"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged --verbose"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "eslint --quiet --fix"
    ],
    "*.{json,md,html,js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  }
}
